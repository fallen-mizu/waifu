<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Waifu - Premium Engine</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #080b11;
        }
        .glass-card {
            background: rgba(13, 18, 30, 0.75);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.03);
        }
        .brand-crimson {
            color: #BC002D;
        }
        .bg-crimson {
            background-color: #BC002D;
        }
        .bg-crimson:hover {
            background-color: #990024;
        }
        .border-crimson:focus {
            border-color: #BC002D;
        }
    </style>
</head>
<body class="text-gray-200 min-h-screen flex flex-col justify-between overflow-x-hidden">

    <header class="w-full border-b border-gray-900 bg-gray-950/40 backdrop-blur-md sticky top-0 z-50 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-red-600 to-rose-700 flex items-center justify-center shadow-lg shadow-red-900/30">
                    <i class="fa-solid fa-wand-magic-sparkles text-white text-md"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-wider uppercase bg-gradient-to-r from-gray-100 to-gray-300 bg-clip-text text-transparent">Waifu</h1>
                    <p class="text-xs text-gray-500 font-mono tracking-widest">Mizu Core System</p>
                </div>
            </div>
            <div class="text-xs text-gray-500 font-mono hidden sm:block">
                STATUS: <span class="brand-crimson animate-pulse"><i class="fa-solid fa-circle text-[9px] mr-1"></i>CONNECTED</span>
            </div>
        </div>
    </header>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <section class="lg:col-span-4 space-y-6">
            <div class="glass-card p-6 rounded-2xl shadow-xl">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-sliders brand-crimson"></i> Control Console
                </h2>
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Manual Database Search</label>
                        <div class="relative">
                            <input type="text" id="search-input" placeholder="Masukkan nama waifu..." 
                                class="w-full bg-gray-950 border border-gray-800 rounded-xl py-3 pl-4 pr-12 text-sm focus:outline-none border-crimson transition-all text-gray-200">
                            <button id="search-btn" class="absolute right-2 top-2 w-8 h-8 rounded-lg bg-gray-900 hover:bg-gray-800 flex items-center justify-center transition-colors">
                                <i class="fa-solid fa-magnifying-glass text-xs text-gray-400"></i>
                            </button>
                        </div>
                    </div>

                    <div class="relative flex py-1 items-center">
                        <div class="flex-grow border-t border-gray-900"></div>
                        <span class="flex-shrink mx-3 text-gray-600 text-[10px] uppercase font-mono">OR</span>
                        <div class="flex-grow border-t border-gray-900"></div>
                    </div>

                    <button id="random-btn" class="w-full bg-crimson text-white text-sm font-medium py-3 px-4 rounded-xl transition-all shadow-lg shadow-red-900/20 active:scale-[0.99] flex items-center justify-center gap-2">
                        <i class="fa-solid fa-dice-five"></i> New Random Waifu
                    </button>
                </div>
            </div>

            <div class="glass-card p-5 rounded-2xl text-xs font-mono text-gray-500 space-y-2.5">
                <div class="flex justify-between border-b border-gray-900 pb-2">
                    <span>Cluster Host:</span>
                    <span class="text-gray-300">Vercel Edge Node</span>
                </div>
                <div class="flex justify-between border-b border-gray-900 pb-2">
                    <span>Data Router:</span>
                    <span class="text-gray-300">Private API Endpoint</span>
                </div>
                <div class="flex justify-between">
                    <span>Render Engine:</span>
                    <span class="brand-crimson">HD Optimized</span>
                </div>
            </div>
        </section>

        <section class="lg:col-span-8 flex flex-col">
            <div class="glass-card rounded-2xl p-4 flex-grow flex flex-col min-h-[520px]">
                
                <div class="flex justify-between items-center border-b border-gray-900 pb-4 mb-4">
                    <h3 id="gallery-title" class="text-xs font-mono tracking-wider text-gray-500 uppercase">
                        Console Idle
                    </h3>
                    <button id="download-btn" disabled class="px-3 py-1.5 bg-gray-900 hover:bg-gray-800 disabled:opacity-30 disabled:hover:bg-gray-900 text-gray-300 rounded-lg text-xs font-medium transition-colors flex items-center gap-1.5">
                        <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i> Open Original
                    </button>
                </div>

                <div class="flex-grow flex items-center justify-center relative overflow-hidden rounded-xl bg-gray-950/40 border border-gray-900/60 min-h-[420px]">
                    
                    <div id="placeholder-view" class="text-center space-y-2.5 p-6">
                        <div class="w-12 h-12 mx-auto rounded-xl bg-gray-950 border border-gray-900 flex items-center justify-center text-gray-600">
                            <i class="fa-regular fa-images text-lg"></i>
                        </div>
                        <p class="text-xs text-gray-500 max-w-xs mx-auto font-sans">Ketik karakter secara spesifik atau picu generator acak untuk menampilkan visual.</p>
                    </div>

                    <div id="loading-view" class="hidden text-center space-y-3">
                        <div class="w-9 h-9 border-2 border-red-600 border-t-transparent rounded-full animate-spin mx-auto"></div>
                        <p class="text-[11px] font-mono tracking-widest text-gray-500 uppercase">Bypassing and Pulling assets...</p>
                    </div>

                    <img id="result-image" src="" alt="Waifu Stream" class="hidden max-h-[72vh] w-full object-contain transition-all duration-300 rounded-lg shadow-2xl">
                </div>
            </div>
        </section>
    </main>

    <footer class="w-full text-center py-5 border-t border-gray-950 text-[11px] font-mono text-gray-600 bg-gray-950/60">
        <p>&copy; 2026 Waifu Vault Project. Powered by Groq AI & Termai API Net.</p>
    </footer>

    <script>
        const randomWaifus = [
            "Arisu Sakayanagi", "Kamisato Ayaka", "Hu Tao", "Raiden Shogun", 
            "Makima", "Kafka Honkai", "Yae Miko", "Kafuu Chino", 
            "Ganyu Genshin", "Rem Re Zero", "Asuka Langley", "Zero Two", 
            "Kurumi Tokisaki", "Chizuru Mizuhara", "Yor Forger", "Elisabeth"
        ];

        const searchInput = document.getElementById('search-input');
        const searchBtn = document.getElementById('search-btn');
        const randomBtn = document.getElementById('random-btn');
        const downloadBtn = document.getElementById('download-btn');
        
        const placeholderView = document.getElementById('placeholder-view');
        const loadingView = document.getElementById('loading-view');
        const resultImage = document.getElementById('result-image');
        const galleryTitle = document.getElementById('gallery-title');

        async function loadWaifu(query) {
            placeholderView.classList.add('hidden');
            resultImage.classList.add('hidden');
            loadingView.classList.remove('hidden');
            downloadBtn.disabled = true;
            galleryTitle.innerText = `FETCHING: ${query.toUpperCase()}`;

            try {
                // Menembak ke Serverless Function milik kita sendiri di Vercel (/api/chat)
                const response = await fetch(`/api/chat?query=${encodeURIComponent(query + " anime icons highres")}`);
                const resData = await response.json();

                if (resData.status && resData.data && resData.data.length > 0) {
                    // Ambil satu gambar secara acak dari data array yang didapat
                    const images = resData.data;
                    const randomImgUrl = images[Math.floor(Math.random() * images.length)];

                    resultImage.src = randomImgUrl;
                    resultImage.onload = () => {
                        loadingView.classList.add('hidden');
                        resultImage.classList.remove('hidden');
                        downloadBtn.disabled = false;
                        galleryTitle.innerText = `READY: ${query.toUpperCase()}`;
                    };
                } else {
                    throw new Error("No assets");
                }
            } catch (err) {
                console.error(err);
                loadingView.classList.add('hidden');
                placeholderView.classList.remove('hidden');
                galleryTitle.innerText = "NODE_DATABASE_ERROR";
                alert("Gagal menarik data dari secure node. Silakan coba karakter lain!");
            }
        }

        searchBtn.addEventListener('click', () => {
            const val = searchInput.value.trim();
            if(val) loadWaifu(val);
        });

        searchInput.addEventListener('keypress', (e) => {
            if(e.key === 'Enter') {
                const val = searchInput.value.trim();
                if(val) loadWaifu(val);
            }
        });

        randomBtn.addEventListener('click', () => {
            const randChar = randomWaifus[Math.floor(Math.random() * randomWaifus.length)];
            searchInput.value = randChar;
            loadWaifu(randChar);
        });

        downloadBtn.addEventListener('click', () => {
            if(resultImage.src) {
                window.open(resultImage.src, '_blank');
            }
        });
    </script>
</body>
</html>
